+// Cozy Forest tiling + hashing helpers
+// Keep allocations out of the render loop. All functions are pure and return primitives.
+
+export const TILE_SIZE = 64;
+
+// Read a tile value from the level in a tolerant way (supports various shapes)
+export function readTile(level, x, y) {
+  if (!level) return undefined;
+  const w = level.width ?? (level.tiles && level.tiles[0] ? level.tiles[0].length : 0);
+  const h = level.height ?? (level.tiles ? level.tiles.length : 0);
+  if (x < 0 || y < 0 || x >= w || y >= h) return undefined;
+  if (typeof level.getTile === 'function') return level.getTile(x, y);
+  if (Array.isArray(level.tiles)) return level.tiles[y]?.[x];
+  return undefined;
+}
+
+export function getLevelSize(level) {
+  if (!level) return { width: 0, height: 0 };
+  const width = level.width ?? (level.tiles && level.tiles[0] ? level.tiles[0].length : 0);
+  const height = level.height ?? (level.tiles ? level.tiles.length : 0);
+  return { width, height };
+}
+
+// Default predicate for deciding if a tile is a wall.
+export function isWallDefault(t) {
+  if (t == null) return false;
+  if (t === 1 || t === 'W' || t === 'wall') return true;
+  if (typeof t === 'object') {
+    const k = t.kind || t.type || t.id;
+    return k === 'wall' || k === 'W' || k === 1;
+  }
+  return false;
+}
+
+// Bitmask order: N=1, E=2, S=4, W=8
+export function neighborMask(level, x, y, isWall = isWallDefault) {
+  let mask = 0;
+  if (isWall(readTile(level, x, y - 1))) mask |= 1;
+  if (isWall(readTile(level, x + 1, y))) mask |= 2;
+  if (isWall(readTile(level, x, y + 1))) mask |= 4;
+  if (isWall(readTile(level, x - 1, y))) mask |= 8;
+  return mask;
+}
+
+// Returns the most exposed direction for a wall-top sprite, preferring corners
+// when two orthogonal sides are exposed. One of: 'n','e','s','w','ne','nw','se','sw'
+export function exposedDir(level, x, y, isWall = isWallDefault) {
+  const n = !isWall(readTile(level, x, y - 1));
+  const e = !isWall(readTile(level, x + 1, y));
+  const s = !isWall(readTile(level, x, y + 1));
+  const w = !isWall(readTile(level, x - 1, y));
+  if (n && w) return 'nw';
+  if (n && e) return 'ne';
+  if (s && w) return 'sw';
+  if (s && e) return 'se';
+  if (n) return 'n';
+  if (e) return 'e';
+  if (s) return 's';
+  if (w) return 'w';
+  return 'n';
+}
+
+// Fast, stable 2D hash (x,y) with an external seed and salt. Returns uint32.
+export function seededHash32(seed, x, y, salt = 0) {
+  // Mix inspired by FNV/xxhash style integer mixing; stays in 32-bit space
+  let h = (2166136261 ^ (seed | 0)) >>> 0;
+  h ^= (x | 0) + 374761393; h = Math.imul(h, 2654435761) >>> 0;
+  h ^= (y | 0) + 1274126177; h = Math.imul(h, 2246822519) >>> 0;
+  h ^= (salt | 0);           h = Math.imul(h, 3266489917) >>> 0;
+  // Final avalanche
+  h ^= h >>> 15; h = Math.imul(h, 2246822507) >>> 0;
+  h ^= h >>> 13; h = Math.imul(h, 3266489909) >>> 0;
+  h ^= h >>> 16;
+  return h >>> 0;
+}
+
+export function stableIndex(seed, x, y, count, salt = 0) {
+  return (seededHash32(seed, x, y, salt) % (count >>> 0)) >>> 0;
+}
+
+export function chance(seed, x, y, salt, probability /* 0..1 */) {
+  const t = (seededHash32(seed, x, y, salt) & 0xffff) / 65536;
+  return t < probability;
+}
+
+export function playerTileXY(state) {
+  const p = state && state.player ? state.player : {};
+  if (Number.isFinite(p.tx) && Number.isFinite(p.ty)) return { x: p.tx | 0, y: p.ty | 0 };
+  const ts = TILE_SIZE;
+  const x = Number.isFinite(p.x) ? Math.max(0, Math.floor(p.x / ts)) : 0;
+  const y = Number.isFinite(p.y) ? Math.max(0, Math.floor(p.y / ts)) : 0;
+  return { x, y };
+}
